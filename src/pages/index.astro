---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Theme toggle — fixed top right -->
  <button
    id="theme-toggle"
    class="fixed top-4 right-4 z-50 p-2.5 rounded-lg text-text-secondary hover:text-text hover:bg-bg-elevated transition-colors"
    aria-label="Toggle theme"
  >
    <svg id="sun-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <svg id="moon-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>

  <!-- Hero -->
  <section class="flex items-start justify-center">
    <div class="mx-auto max-w-3xl px-6 pt-12 pb-16 text-center">
      <!-- Mascot -->
      <div class="mb-2">
        <img src="/crab.svg" alt="PhysiClaw crab mascot" class="w-40 h-40 sm:w-48 sm:h-48 mx-auto drop-shadow-lg" />
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-[3.5rem] font-bold tracking-tight leading-none mb-3 text-accent">
        PhysiClaw
      </h1>

      <p class="text-lg sm:text-xl text-accent/70 font-normal mb-5">
        The AI that physically uses your phone.
      </p>

      <p class="text-[15px] sm:text-base text-text-secondary max-w-lg mx-auto mb-6 leading-[1.7]">
        Order food, hail rides, check your bank, reply to messages.<br/>
        Any app, any phone, no APIs, no OAuth.
      </p>

    </div>
  </section>

  <!-- Demo — How it works in practice -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Left: Claude Desktop mockup -->
        <div class="bg-bg-elevated border border-border rounded-xl overflow-hidden">
          <!-- Window chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-border-subtle">
            <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
            <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
            <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
            <span class="ml-3 text-text-tertiary text-xs font-mono">Claude Desktop</span>
          </div>
          <!-- Chat -->
          <div class="p-5 space-y-4">
            <!-- User message -->
            <div class="flex justify-end">
              <div class="bg-accent/15 border border-accent/20 rounded-xl rounded-br-sm px-4 py-2.5 max-w-[85%]">
                <p class="text-sm text-text">Pizza for dinner on Uber Eats</p>
              </div>
            </div>
            <!-- AI response -->
            <div class="flex justify-start">
              <div class="bg-bg-card border border-border-subtle rounded-xl rounded-bl-sm px-4 py-3 max-w-[90%]">
                <p class="text-sm text-text-secondary leading-relaxed">
                  On it. I'll open Uber Eats on your phone, find a pizza place nearby, and place the order.
                </p>
                <div class="mt-3 space-y-2 font-mono text-xs">
                  <div class="flex items-center gap-2 text-green">
                    <span>&#x2713;</span>
                    <span>screenshot_top()</span>
                  </div>
                  <div class="flex items-center gap-2 text-green">
                    <span>&#x2713;</span>
                    <span>move("down-right", "large")</span>
                  </div>
                  <div class="flex items-center gap-2 text-green">
                    <span>&#x2713;</span>
                    <span>tap() — Uber Eats icon</span>
                  </div>
                  <div class="flex items-center gap-2 text-green">
                    <span>&#x2713;</span>
                    <span>screenshot_top()</span>
                  </div>
                  <div class="flex items-center gap-2 text-yellow">
                    <span class="inline-block w-2 h-2 rounded-full bg-yellow animate-pulse"></span>
                    <span class="text-text-tertiary">searching for pizza...</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Robot arm + phone illustration -->
        <div class="flex items-center justify-center">
          <img src="/arm-phone.svg" alt="Robot arm touching phone screen" class="w-full max-w-md" />
        </div>

      </div>

      <p class="text-center text-xs text-text-tertiary mt-6">
        The entire flow runs autonomously. You just watch.
      </p>
    </div>
  </section>

  <!-- The Loop — ASCII diagram -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-6">
      <div class="bg-bg-elevated border border-border rounded-xl p-6 sm:p-8 overflow-x-auto">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-text-tertiary font-mono text-xs">the loop</span>
        </div>
        <pre class="font-mono text-accent/90 ascii-diagram whitespace-pre"><code>{` Top Camera ──→ AI Agent ──→ 3-Axis Arm ──→ Side Camera ──→ Aligned?
 (read screen)  (decide)     (move stylus)   (check pos)     │
      ▲                                                  Yes │ No
      │                                                   │  │
      │         Touch Phone ◄─────────────────────────────┘  │
      │              │                                       │
      └──────────────┘ (next action)         adjust & retry ◄┘`}</code></pre>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how">
    <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
      <div class="flex items-center gap-3 mb-12">
        <span class="text-accent font-mono text-sm">&gt;</span>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">How it works</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-border bg-bg-card p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent font-mono text-sm font-bold">1</span>
            <h3 class="font-semibold text-[15px]">Park & Screenshot</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            Stylus retracts out of frame. Top camera takes a clean screenshot. The AI sees exactly what's on your phone screen.
          </p>
        </div>

        <div class="rounded-xl border border-border bg-bg-card p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent font-mono text-sm font-bold">2</span>
            <h3 class="font-semibold text-[15px]">AI Decides</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            The agent (Claude, GPT, etc.) analyzes the screen and picks a direction and distance — like "move down-right, large" — no pixel coordinates needed.
          </p>
        </div>

        <div class="rounded-xl border border-border bg-bg-card p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent font-mono text-sm font-bold">3</span>
            <h3 class="font-semibold text-[15px]">Move & Verify</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            The arm moves the stylus. Side camera checks alignment from 45°. Not aligned? The AI adjusts. Aligned? It taps.
          </p>
        </div>

        <div class="rounded-xl border border-border bg-bg-card p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent font-mono text-sm font-bold">4</span>
            <h3 class="font-semibold text-[15px]">Touch & Repeat</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            Stylus touches the screen, then retracts. Top camera verifies the result. The loop continues for the next action.
          </p>
        </div>
      </div>

      <!-- Two cameras explanation -->
      <div class="mt-8 grid sm:grid-cols-3 gap-4">
        <div class="rounded-xl border border-border-subtle bg-bg-elevated p-5">
          <div class="text-lg mb-2">&#x1F4F7;</div>
          <h4 class="font-medium text-sm mb-1">Top Camera</h4>
          <p class="text-text-tertiary text-xs leading-relaxed">Looks straight down at the screen — reads what's on it</p>
        </div>
        <div class="rounded-xl border border-border-subtle bg-bg-elevated p-5">
          <div class="text-lg mb-2">&#x1F4D0;</div>
          <h4 class="font-medium text-sm mb-1">Side Camera</h4>
          <p class="text-text-tertiary text-xs leading-relaxed">Views from ~45° — checks stylus tip position before tapping</p>
        </div>
        <div class="rounded-xl border border-border-subtle bg-bg-elevated p-5">
          <div class="text-lg mb-2">&#x270F;&#xFE0F;</div>
          <h4 class="font-medium text-sm mb-1">Capacitive Stylus</h4>
          <p class="text-text-tertiary text-xs leading-relaxed">Moves X/Y to reach any point, up/down (Z) to touch or release</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why -->
  <section id="why">
    <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-accent font-mono text-sm">&gt;</span>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Why PhysiClaw</h2>
      </div>

      <p class="text-text-secondary text-lg max-w-2xl mb-12 leading-relaxed">
        Today's AI agents can control your computer — but they hit walls everywhere.
      </p>

      <div class="grid sm:grid-cols-2 gap-6 mb-12">
        <div class="space-y-3">
          <h3 class="text-xs font-mono text-text-tertiary uppercase tracking-widest mb-4">The Problem</h3>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-red-400 mt-0.5 shrink-0">&#x2715;</span>
            <span>Want to order food? Need a delivery API + OAuth.</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-red-400 mt-0.5 shrink-0">&#x2715;</span>
            <span>Want to check your bank? Blocked by data walls.</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-red-400 mt-0.5 shrink-0">&#x2715;</span>
            <span>Want to book a ride? Another service integration.</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-red-400 mt-0.5 shrink-0">&#x2715;</span>
            <span>Every new app = new OAuth, new API, new setup.</span>
          </div>
        </div>

        <div class="space-y-3">
          <h3 class="text-xs font-mono text-text-tertiary uppercase tracking-widest mb-4">The PhysiClaw Way</h3>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-green mt-0.5 shrink-0">&#x2713;</span>
            <span>One setup. Every app. Any phone.</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-green mt-0.5 shrink-0">&#x2713;</span>
            <span>No API keys. No OAuth. No integrations.</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-green mt-0.5 shrink-0">&#x2713;</span>
            <span>Invisible to apps — just a finger on glass.</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-text-secondary">
            <span class="text-green mt-0.5 shrink-0">&#x2713;</span>
            <span>iOS and Android. No jailbreak needed.</span>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-accent/20 bg-accent-glow p-6 sm:p-8">
        <p class="text-[15px] leading-relaxed">
          <strong class="text-accent">The insight:</strong>
          <span class="text-text-secondary"> Instead of building software bridges to every service, give the AI agent physical presence. A camera sees the screen. A robotic finger taps it. No app can detect or block it — because to the phone, it's just a finger.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
      <div class="flex items-center gap-3 mb-12">
        <span class="text-accent font-mono text-sm">&gt;</span>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">System Architecture</h2>
      </div>

      <div class="bg-bg-elevated border border-border rounded-xl p-6 sm:p-8 overflow-x-auto">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-text-tertiary font-mono text-xs">architecture.txt</span>
        </div>
        <pre class="font-mono text-green/80 ascii-diagram whitespace-pre"><code>{`┌───────────────────────────────────────┐
│           AI Agent (Brain)            │
│  Claude Desktop / OpenClaw / etc.     │
│  Sees screen → decides → calls tools  │
└──────────────────┬────────────────────┘
                   │ MCP Protocol
                   ▼
┌───────────────────────────────────────┐
│     PhysiClaw MCP Server (Python)     │
│                                       │
│  Tools:                               │
│   · screenshot_top   (top camera)     │
│   · screenshot_side  (side camera)    │
│   · move             (X/Y plane)      │
│   · tap / swipe      (Z down + move)  │
│   · park             (retract)        │
└──────────┬────────────────┬───────────┘
           │                │
     USB Cameras      USB Serial (GRBL)
           │                │
           ▼                ▼
    ┌────────────┐   ┌───────────────┐
    │ Top Camera │   │ GRBL Board    │
    │ (screen)   │   │ (embedded)    │
    ├────────────┤   │ X/Y gantry    │
    │ Side Camera│   │ Z stylus      │
    │ (stylus)   │   └──────┬────────┘
    └────────────┘          │ touch
                            ▼
                   ┌─────────────────┐
                   │  Phone          │
                   │  (unlocked)     │
                   └─────────────────┘`}</code></pre>
      </div>

      <div class="mt-6 flex flex-wrap gap-2">
        {['Python 3.11+', 'MCP Protocol', 'GRBL/grblHAL', 'OpenCV', 'pyserial', 'USB Serial'].map((tech) => (
          <span class="px-3 py-1 rounded-full text-xs font-mono text-text-tertiary border border-border-subtle bg-bg-elevated">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Hardware / BOM -->
  <section id="hardware">
    <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-accent font-mono text-sm">&gt;</span>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Hardware</h2>
      </div>
      <p class="text-text-secondary text-sm mb-10">Everything you need to build one. Total cost: <strong class="text-text">~$127</strong>.</p>

      <div class="rounded-xl border border-border overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-bg-elevated text-left">
              <th class="px-5 py-3 font-medium text-text-tertiary text-xs uppercase tracking-wider">Component</th>
              <th class="px-5 py-3 font-medium text-text-tertiary text-xs uppercase tracking-wider hidden sm:table-cell">Item</th>
              <th class="px-5 py-3 font-medium text-text-tertiary text-xs uppercase tracking-wider text-right">Price</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-subtle">
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">GRBL Arm</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">Paixi pen plotter P25 (X/Y gantry + Z servo)</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$80</td>
            </tr>
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">Top Camera</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">UGREEN 1080P USB camera, fixed focus</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$14</td>
            </tr>
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">Side Camera</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">UGREEN 1080P USB camera (same)</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$14</td>
            </tr>
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">Stylus</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">Capacitive stylus, conductive fiber tip 8-10mm</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$1.50</td>
            </tr>
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">Camera Mounts</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">Gooseneck desk clamp, metal, 50cm (x2)</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$4</td>
            </tr>
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">Phone Mount</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">Anti-slip pad + L-shaped blocks</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$1.20</td>
            </tr>
            <tr class="hover:bg-bg-elevated/50 transition-colors">
              <td class="px-5 py-3 font-medium text-text whitespace-nowrap">USB Hub</td>
              <td class="px-5 py-3 text-text-secondary hidden sm:table-cell">USB 3.0 Hub</td>
              <td class="px-5 py-3 text-text-secondary text-right font-mono">~$13</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
      <div class="flex items-center gap-3 mb-12">
        <span class="text-accent font-mono text-sm">&gt;</span>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Quick Start</h2>
      </div>

      <div class="space-y-4 max-w-2xl">
        <div class="bg-bg-elevated border border-border rounded-xl p-5">
          <div class="text-xs font-mono text-text-tertiary mb-3">Install dependencies</div>
          <pre class="font-mono text-sm text-green"><code>pip install pyserial opencv-python mcp</code></pre>
        </div>

        <div class="bg-bg-elevated border border-border rounded-xl p-5">
          <div class="text-xs font-mono text-text-tertiary mb-3">Clone the repo</div>
          <pre class="font-mono text-sm text-green"><code>git clone https://github.com/echosprint/PhysiClaw.git
cd PhysiClaw</code></pre>
        </div>

        <div class="bg-bg-elevated border border-border rounded-xl p-5">
          <div class="text-xs font-mono text-text-tertiary mb-3">Project structure</div>
          <pre class="font-mono text-sm text-text-secondary"><code><span class="text-accent">physiclaw/</span>
├── physiclaw_server.py   <span class="text-text-tertiary"># MCP Server entry point</span>
├── hand.py               <span class="text-text-tertiary"># Serial G-code control</span>
├── eyes.py               <span class="text-text-tertiary"># USB camera capture</span>
└── config.py             <span class="text-text-tertiary"># Configuration constants</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section id="cases">
    <div class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-accent font-mono text-sm">&gt;</span>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">What it can do</h2>
      </div>
      <p class="text-text-secondary text-sm mb-10">Any app, any phone, iOS or Android.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
          <span class="text-lg shrink-0 mt-0.5">&#x1F35C;</span>
          <div>
            <div class="text-sm font-medium text-text">Order food delivery</div>
            <div class="text-xs text-text-tertiary mt-0.5">Meituan, Uber Eats</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
          <span class="text-lg shrink-0 mt-0.5">&#x1F697;</span>
          <div>
            <div class="text-sm font-medium text-text">Hail a ride</div>
            <div class="text-xs text-text-tertiary mt-0.5">Didi, Uber</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
          <span class="text-lg shrink-0 mt-0.5">&#x1F6D2;</span>
          <div>
            <div class="text-sm font-medium text-text">Browse & shop</div>
            <div class="text-xs text-text-tertiary mt-0.5">Taobao, Amazon</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
          <span class="text-lg shrink-0 mt-0.5">&#x1F4CA;</span>
          <div>
            <div class="text-sm font-medium text-text">Check weather, news, stocks</div>
            <div class="text-xs text-text-tertiary mt-0.5">Any app</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
          <span class="text-lg shrink-0 mt-0.5">&#x1F4AC;</span>
          <div>
            <div class="text-sm font-medium text-text">Read & reply to messages</div>
            <div class="text-xs text-text-tertiary mt-0.5">WeChat, WhatsApp</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
          <span class="text-lg shrink-0 mt-0.5">&#x1F4F1;</span>
          <div>
            <div class="text-sm font-medium text-text">Scroll social media</div>
