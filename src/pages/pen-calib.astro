<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pen Calibration</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { overflow: hidden; }
      #screen {
        position: fixed;
        inset: 0;
        background: #ffffff;
        transition: background-color 0.15s;
      }
      .target {
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #e85d26;
        border: none;
        cursor: pointer;
        transform: translate(-50%, -50%);
      }
      .target.hidden { display: none; }
      #label {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        font-family: system-ui, sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #333;
        text-align: center;
      }
      @keyframes pulse-ring {
        0% { transform: translate(-50%,-50%) scale(1); opacity: 0.6; }
        100% { transform: translate(-50%,-50%) scale(1.8); opacity: 0; }
      }
      @keyframes dash-spin {
        to { stroke-dashoffset: 0; }
      }
    </style>
  </head>
  <body>
    <div id="screen">
      <div id="label">Tap the center circle</div>
      <button id="t0" class="target" style="top:50%; left:50%;"></button>
      <button id="t1" class="target hidden" style="top:50%; left:62%;"></button>
      <button id="t2" class="target hidden" style="top:62%; left:50%;"></button>
    </div>
    <script>
      const screen = document.getElementById('screen') as HTMLDivElement;
      const label = document.getElementById('label') as HTMLDivElement;
      const targets = [
        document.getElementById('t0') as HTMLButtonElement,
        document.getElementById('t1') as HTMLButtonElement,
        document.getElementById('t2') as HTMLButtonElement,
      ];

      // --- Phase 1: Tap center circle 10 times, then right, then down ---
      const TAP_CENTER_REQUIRED = 10;
      const TAP_DIR_REQUIRED = 3;
      let tapCount = 0;

      function startCenterTap() {
        tapCount = 0;
        let locked = false;
        const btn = targets[0];
        btn.classList.remove('hidden');
        label.textContent = `Tap center circle: ${tapCount}/${TAP_CENTER_REQUIRED}`;

        const handler = () => {
          if (locked) return;
          locked = true;
          tapCount++;
          label.textContent = `Tap center circle: ${tapCount}/${TAP_CENTER_REQUIRED}`;
          screen.style.backgroundColor = '#22c55e';
          setTimeout(() => {
            screen.style.backgroundColor = '#ffffff';
            if (tapCount >= TAP_CENTER_REQUIRED) {
              btn.removeEventListener('pointerdown', handler);
              btn.classList.add('hidden');
              startRightTap();
            } else {
              locked = false;
            }
          }, 1000);
        };
        btn.addEventListener('pointerdown', handler);
      }

      function startRightTap() {
        let count = 0;
        let locked = false;
        const btn = targets[1];
        btn.classList.remove('hidden');
        label.textContent = `Tap RIGHT →: ${count}/${TAP_DIR_REQUIRED}`;

        const handler = () => {
          if (locked) return;
          locked = true;
          count++;
          label.textContent = `Tap RIGHT →: ${count}/${TAP_DIR_REQUIRED}`;
          screen.style.backgroundColor = '#22c55e';
          setTimeout(() => {
            screen.style.backgroundColor = '#ffffff';
            if (count >= TAP_DIR_REQUIRED) {
              btn.removeEventListener('pointerdown', handler);
              btn.classList.add('hidden');
              startDownTap();
            } else {
              locked = false;
            }
          }, 1000);
        };
        btn.addEventListener('pointerdown', handler);
      }

      function startDownTap() {
        let count = 0;
        let locked = false;
        const btn = targets[2];
        btn.classList.remove('hidden');
        label.textContent = `Tap DOWN ↓: ${count}/${TAP_DIR_REQUIRED}`;

        const handler = () => {
          if (locked) return;
          locked = true;
          count++;
          label.textContent = `Tap DOWN ↓: ${count}/${TAP_DIR_REQUIRED}`;
          screen.style.backgroundColor = '#22c55e';
          setTimeout(() => {
            screen.style.backgroundColor = '#ffffff';
            if (count >= TAP_DIR_REQUIRED) {
              btn.removeEventListener('pointerdown', handler);
              btn.classList.add('hidden');
              startLongPressTest();
            } else {
              locked = false;
            }
          }, 1000);
        };
        btn.addEventListener('pointerdown', handler);
      }

      startCenterTap();

      // --- Long press test (center circle, 10 times, green 1s each) ---
      const LONG_PRESS_MS = 800;
      const TOTAL_PRESSES = 3;
      let pressHits = 0;

      function startLongPressTest() {
        pressHits = 0;
        let pressStarted = false;
        let locked = false;
        let pressTimer: ReturnType<typeof setTimeout> | undefined = undefined;
        const btn = targets[0];
        btn.classList.remove('hidden');
        label.textContent = `Long press center: ${pressHits}/${TOTAL_PRESSES}`;

        const downHandler = (e: PointerEvent) => {
          e.stopPropagation();
          if (locked) return;
          pressStarted = true;
          btn.style.background = '#c44d1e';
          pressTimer = setTimeout(() => {
            pressStarted = false;
            locked = true;
            pressHits++;
            btn.style.background = '#e85d26';
            label.textContent = `Long press center: ${pressHits}/${TOTAL_PRESSES}`;
            screen.style.backgroundColor = '#22c55e';
            setTimeout(() => {
              screen.style.backgroundColor = '#ffffff';
              if (pressHits >= TOTAL_PRESSES) {
                btn.removeEventListener('pointerdown', downHandler);
                btn.removeEventListener('pointerup', upHandler);
                btn.classList.add('hidden');
                startSwipeTest();
              } else {
                locked = false;
              }
            }, 1000);
          }, LONG_PRESS_MS);
        };

        const upHandler = (e: PointerEvent) => {
          e.stopPropagation();
          if (locked || !pressStarted) return;
          pressStarted = false;
          clearTimeout(pressTimer);
          btn.style.background = '#e85d26';
        };

        btn.addEventListener('pointerdown', downHandler);
        btn.addEventListener('pointerup', upHandler);
      }

      // --- Phase 4: Swipe calibration (center→up, down, right, left) ---
      // Orange circle = start (center), blue circle = destination, arrow between them
      const SWIPE_DIRS: Array<{ name: string; destTop: string; destLeft: string; arrowTop: string; arrowLeft: string; arrow: string }> = [
        { name: 'Swipe UP',    destTop: '38%', destLeft: '50%', arrowTop: '44%', arrowLeft: '50%', arrow: '↑' },
        { name: 'Swipe DOWN',  destTop: '62%', destLeft: '50%', arrowTop: '56%', arrowLeft: '50%', arrow: '↓' },
        { name: 'Swipe RIGHT', destTop: '50%', destLeft: '62%', arrowTop: '50%', arrowLeft: '56%', arrow: '→' },
        { name: 'Swipe LEFT',  destTop: '50%', destLeft: '38%', arrowTop: '50%', arrowLeft: '44%', arrow: '←' },
      ];
      const SWIPE_THRESHOLD = 60;
      let swipeIdx = 0;
      let swipeHits = 0;

      // Swipe state — single set of listeners, no recursion
      let swipeLocked = false;
      let swipeStartX = 0;
      let swipeStartY = 0;
      let swipeElements: HTMLElement[] = [];

      function swipeCleanup() {
        swipeElements.forEach(el => el.remove());
        swipeElements = [];
        targets[0].classList.add('hidden');
        targets[0].style.top = '50%';
        targets[0].style.left = '50%';
      }

      function swipeRender() {
        const dir = SWIPE_DIRS[swipeIdx];
        const destTopVal = parseFloat(dir.destTop);
        const destLeftVal = parseFloat(dir.destLeft);

        label.textContent = `${dir.name}  (${swipeIdx + 1}/${SWIPE_DIRS.length})`;

        targets[0].classList.remove('hidden');
        targets[0].style.top = '50%';
        targets[0].style.left = '50%';

        // Dashed circle destination
        const dest = document.createElement('div');
        dest.innerHTML = `<svg width="80" height="80" viewBox="0 0 80 80"><circle cx="40" cy="40" r="36" fill="none" stroke="#3b82f6" stroke-width="3" stroke-dasharray="8 6" style="animation: dash-spin 2s linear infinite; stroke-dashoffset: 56;"/></svg>`;
        dest.style.cssText = `position:absolute;width:80px;height:80px;transform:translate(-50%,-50%);pointer-events:none;top:${dir.destTop};left:${dir.destLeft};`;
        screen.appendChild(dest);
        swipeElements.push(dest);

        // Arrows between circles
        for (let i = 0; i < 3; i++) {
          const a = document.createElement('div');
          const t = (i + 1) / 4;
          const top = 50 + (destTopVal - 50) * t;
          const left = 50 + (destLeftVal - 50) * t;
          a.style.cssText = `position:absolute;top:${top}%;left:${left}%;transform:translate(-50%,-50%);font-size:28px;color:#e85d26;opacity:${0.3 + t * 0.5};user-select:none;pointer-events:none;`;
          a.textContent = dir.arrow;
          screen.appendChild(a);
          swipeElements.push(a);
        }
      }

      function swipeOnDown(e: PointerEvent) {
        if (swipeLocked) return;
        // Only start swipe if touching the orange circle
        if (e.target !== targets[0]) return;
        swipeStartX = e.clientX;
        swipeStartY = e.clientY;
      }

      function swipeOnMove(e: PointerEvent) {
        if (swipeLocked || (swipeStartX === 0 && swipeStartY === 0)) return;
        const dx = e.clientX - swipeStartX;
        const dy = e.clientY - swipeStartY;
        const sh = window.innerHeight;
        const sw = window.innerWidth;
        targets[0].style.top = `${50 + (dy / sh) * 100}%`;
        targets[0].style.left = `${50 + (dx / sw) * 100}%`;
      }

      function swipeOnUp(e: PointerEvent) {
        if (swipeLocked) return;
        if (swipeStartX === 0 && swipeStartY === 0) return;

        const dx = e.clientX - swipeStartX;
        const dy = e.clientY - swipeStartY;
        swipeStartX = 0;
        swipeStartY = 0;

        let detected: string | null = null;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > SWIPE_THRESHOLD) {
          detected = dx > 0 ? 'right' : 'left';
        } else if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > SWIPE_THRESHOLD) {
          detected = dy > 0 ? 'down' : 'up';
        }

        const dir = SWIPE_DIRS[swipeIdx];
        const expectedMap: Record<string, string> = { '↑': 'up', '↓': 'down', '→': 'right', '←': 'left' };

        if (detected === expectedMap[dir.arrow]) {
          // SUCCESS — lock, green 1s, then advance
          swipeLocked = true;
          swipeHits++;
          targets[0].style.top = dir.destTop;
          targets[0].style.left = dir.destLeft;
          screen.style.backgroundColor = '#22c55e';
          label.textContent = `${dir.name} — OK`;

          setTimeout(() => {
            screen.style.backgroundColor = '#ffffff';
            swipeCleanup();
            swipeIdx++;
            swipeLocked = false;

            if (swipeIdx >= SWIPE_DIRS.length) {
              // Remove listeners, done
              screen.removeEventListener('pointerdown', swipeOnDown);
              screen.removeEventListener('pointermove', swipeOnMove);
              screen.removeEventListener('pointerup', swipeOnUp);
              finishSwipeTest();
            } else {
              swipeRender();
            }
          }, 1000);
        } else {
          // FAIL — reset circle to center, retry
          targets[0].style.top = '50%';
          targets[0].style.left = '50%';
        }
      }

      function startSwipeTest() {
        swipeIdx = 0;
        swipeHits = 0;
        swipeLocked = false;
        swipeRender();
        screen.addEventListener('pointerdown', swipeOnDown);
        screen.addEventListener('pointermove', swipeOnMove);
        screen.addEventListener('pointerup', swipeOnUp);
      }

      function finishSwipeTest() {
        label.textContent = `Calibration complete! Swipe: ${swipeHits}/${SWIPE_DIRS.length}`;
        screen.style.backgroundColor = '#22c55e';
      }
    </script>
  </body>
</html>
